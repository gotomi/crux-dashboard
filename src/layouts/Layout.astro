---
// src/layouts/BaseLayout.astro
const { title } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="stylesheet" href="/style/global.css" />
    </head>
    <body>
        <slot />
    </body>
</html>

<style>
    nav ul,
    li {
        list-style: none;
        margin-bottom: 2em;
    }

    nav li {
        display: inline-block;
        margin: 0 10px;
    }
    nav span {
        color: bisque;
        font-weight: bold;
    }
    nav ul {
        background: #000;
        padding: 5px;
        right: 0;
        top: 0;
    }
    nav a,
    nav li {
        color: #fff;
    }
</style>
